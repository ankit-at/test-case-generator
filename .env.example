# Copy to .env and fill in. .env is gitignored and must never be committed.

# --- Generation engine (required) ---
ANTHROPIC_API_KEY=

# Optional model / generation overrides
TCGEN_MODEL=claude-sonnet-4-6
TCGEN_MAX_TOKENS=2000
TCGEN_TEMPERATURE=0.7

# --- Web server ---
PORT=3001

# REQUIRED: a strong random secret, at least 16 chars. The server refuses to
# start without it. Generate one, e.g.:  openssl rand -base64 32
JWT_SECRET=

# Comma-separated list of allowed browser origins for CORS.
CORS_ORIGIN=http://localhost:5173

# --- Seed admin (created on first boot only) ---
ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Administrator
# Optional: set your own admin password (>= 8 chars, not a common default).
# If left blank, a strong random password is generated and printed to the
# server console once on first boot.
ADMIN_PASSWORD=

# Optional: override SQLite path (defaults to ./tcgen.db)
# TCGEN_DB_PATH=./tcgen.db
