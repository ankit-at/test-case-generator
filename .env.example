# Copy to .env and fill in.

# --- Generation engine (required) ---
ANTHROPIC_API_KEY=

# Optional model / generation overrides
TCGEN_MODEL=claude-sonnet-4-6
TCGEN_MAX_TOKENS=2000
TCGEN_TEMPERATURE=0.7

# --- Web server ---
PORT=3001
JWT_SECRET=change-me-to-a-long-random-string

# Seed admin, created on first boot if the database is empty.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator

# Optional: override SQLite path (defaults to ./tcgen.db)
# TCGEN_DB_PATH=./tcgen.db
