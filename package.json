{
  "name": "test-case-generator",
  "version": "1.0.0",
  "description": "Generate production-ready test cases from a BRD or skills inventory using an LLM, with a web UI.",
  "type": "commonjs",
  "bin": {
    "tcgen": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "generate": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "server": "ts-node --project server/tsconfig.json server/index.ts",
    "server:check": "tsc --noEmit -p server/tsconfig.json",
    "web": "vite",
    "web:build": "vite build",
    "app": "concurrently -n server,web -c blue,green \"npm run server\" \"npm run web\""
  },
  "keywords": [
    "testing",
    "test-generation",
    "playwright",
    "qa",
    "automation",
    "brd"
  ],
  "author": "Ankit Tiwari",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "ajv": "^8.17.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "engines": {
    "node": ">=18"
  }
}
